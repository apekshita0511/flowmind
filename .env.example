# Backend (Django) Configuration
SECRET_KEY=your-django-secret-key-change-in-production
GROQ_API_KEY=your-groq-api-key-from-groq-console

# Database URL (for production)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/flowmind

# Debug mode (set to False in production)
DEBUG=False

# React Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# For Render Deployment
# REACT_APP_API_URL=https://flowmind-backend.onrender.com
# REACT_APP_API_BASE_URL=https://flowmind-backend.onrender.com/api/v1
